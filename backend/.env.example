# ---- App ----
APP_ENV=development
API_BASE_URL=http://localhost:8000

# ---- Mock flags (v1.1) ----
# All default true: a fresh clone runs the ENTIRE product with zero credentials.
# Flip each to false only once the matching real keys below are filled (see SETUP.md).
MOCK_INFERENCE=true   # true -> MockProvider (deterministic, no cost). false -> Fal.ai (needs FAL_API_KEY)
MOCK_AUTH=true        # true -> "Bearer mock-dev-token" resolves to a dev user. false -> verify Supabase JWT
MOCK_PAYMENTS=true    # true -> purchase auto-succeeds. false -> real YooKassa (webhook stays real either way)

# ---- Supabase ----
# Dedicated project: https://htclwrotnmhtbrdisqcu.supabase.co
SUPABASE_URL=https://htclwrotnmhtbrdisqcu.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Service-role key bypasses RLS — server-side only, never ship to clients.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# JWT secret used to verify Supabase access tokens (Project Settings → API → JWT Secret).
SUPABASE_JWT_SECRET=your-jwt-secret
# Private storage bucket holding original + result photos.
SUPABASE_STORAGE_BUCKET=photos
# Postgres schema for app tables. Keep "public" for the dedicated project; set to a
# namespace (e.g. "smile") only when sharing a project (must be exposed to PostgREST).
SUPABASE_DB_SCHEMA=public

# ---- Inference (Fal.ai) ----
INFERENCE_PROVIDER=fal_flux_pro_fill
FAL_API_KEY=your-fal-key
FAL_FLUX_FILL_ENDPOINT=fal-ai/flux-pro/v1/fill

# ---- Face detection (MediaPipe Tasks) ----
# Path to the FaceLandmarker model bundle. Defaults to api-gateway/.cache/face_landmarker.task.
# Download once:
#   curl -L -o .cache/face_landmarker.task \
#     https://storage.googleapis.com/mediapipe-models/face_landmarker/face_landmarker/float16/1/face_landmarker.task
# Requires the `ml` extra (mediapipe + opencv) and OpenGL libs (libgles2 libegl1 libgl1).
MEDIAPIPE_FACE_MODEL=

# ---- Limits ----
FREE_GENERATIONS=1
RATE_LIMIT_PER_MINUTE=5

# ---- Payments ----
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
CLICK_SECRET_KEY=

# ---- Admin / clinic auth ----
ADMIN_API_KEY=change-me

# ---- Clinic notifications (Phase 5) ----
# Email (MVP fallback). Leave SMTP_HOST empty to disable email notifications.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=AI Smile Simulator <noreply@smilesim.app>
SMTP_USE_TLS=true
# WhatsApp Business API (preferred). Leave token empty to disable.
WHATSAPP_API_BASE=https://graph.facebook.com/v21.0
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ---- Error tracking (Sentry) ----
# Leave empty to disable. When set, backend + Flutter report errors here.
SENTRY_DSN=

# ---- Misc ----
PHOTO_RETENTION_DAYS=30
RESULT_IMAGE_SIZE=1024
